<!doctype html>
<html lang="en" style="background:#111214">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }} — Toby Thomson</title>
  <meta name="description" content="{{ description or "Toby Thomson" }}">
  <link rel="preload" href="/fonts/InterVariable.woff2" as="font" type="font/woff2" crossorigin>
  <style>{% include "style.css" %}</style>
</head>
<body>
  <div class="shell">
    <header class="site-header">
      <span class="site-name">Toby Thomson</span>
      <nav class="site-nav">
        <a href="/"{% if page.url == "/" %} aria-current="page"{% endif %}>About</a>
        <a href="/portfolio/"{% if page.url == "/portfolio/" %} aria-current="page"{% endif %}>Portfolio</a>
        <a href="/contact/"{% if page.url == "/contact/" %} aria-current="page"{% endif %}>Contact</a>
      </nav>
    </header>
    <main class="content">
      {{ content | safe }}
    </main>
  </div>
</body>
</html>
